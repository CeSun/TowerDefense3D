<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             x:Class="TowerDefense.MapListControl">
    <Grid>
        <!-- 3D Preview fills entire screen -->
        <a:Aura3DView x:Name="PreviewView"
                       SceneInitialized="OnPreviewSceneInit"
                       SceneUpdated="OnPreviewSceneUpdated" />

        <!-- Selection overlay -->
        <Grid ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="#CC0d0d1a" Padding="12,8" Margin="8,8,8,0"
                    CornerRadius="6">
                <DockPanel>
                    <Button x:Name="BackBtn" Click="OnMainMenuClick"
                            DockPanel.Dock="Left"
                            Background="#CC4a6a8a" Foreground="White"
                            FontSize="12" FontWeight="Bold"
                            Padding="10,6" CornerRadius="4"
                            Margin="0,0,12,0">
                        ↩ Back
                    </Button>
                    <TextBlock DockPanel.Dock="Left" Text="EDIT MAPS" Foreground="White"
                               FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock x:Name="MapListStatus" DockPanel.Dock="Left" Foreground="#AAA" FontSize="13"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               Text="Select a map to edit, or create a new one" />
                    <Button x:Name="NewMapBtn" Click="OnNewMap"
                            Background="#CC2d6a4a" Foreground="White"
                            FontSize="12" FontWeight="Bold"
                            Padding="12,6" CornerRadius="4"
                            HorizontalAlignment="Right">
                        🆕 New Map
                    </Button>
                </DockPanel>
            </Border>

            <!-- Map card grid (left) -->
            <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="8,4,4,8">
                <WrapPanel x:Name="MapCardGrid" Margin="4" />
            </ScrollViewer>

            <!-- Detail panel (right) -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="#EE1a1a2e" CornerRadius="6"
                    Padding="14" Margin="4,4,8,8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="DetailMapName" Text="Select a Map"
                               Foreground="White" FontSize="22" FontWeight="Bold" />
                    <Separator Background="#444" Height="1" />
                    <TextBlock x:Name="DetailMapGrid" Text="Grid: -"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailMapWaves" Text="Waves: -"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailMapEnemies" Text="Enemies: -"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailMapPath" Text="Path: -"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailMapStatus" Text=""
                               Foreground="#888" FontSize="11"
                               TextWrapping="Wrap" />

                    <Separator Background="#444" Height="1" />

                    <!-- Edit / Delete buttons -->
                    <StackPanel Spacing="4">
                        <Button x:Name="EditMapBtn" Click="OnEditMapClick"
                                Background="#CC3a8a3a" Foreground="White"
                                FontSize="14" FontWeight="Bold"
                                Padding="14,10" CornerRadius="6"
                                HorizontalAlignment="Stretch"
                                IsVisible="False">
                            ✏ Edit Map
                        </Button>
                        <Button x:Name="DeleteMapBtn" Click="OnDeleteMap"
                                Background="#CC6a2a2a" Foreground="White"
                                FontSize="12"
                                Padding="10,6" CornerRadius="4"
                                HorizontalAlignment="Stretch"
                                IsVisible="False">
                            🗑 Delete Map
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
