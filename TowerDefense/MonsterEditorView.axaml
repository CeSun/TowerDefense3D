<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             x:Class="TowerDefense.MonsterEditorView">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- 3D Preview -->
        <a:Aura3DView Grid.Column="0"
                       x:Name="PreviewView"
                       SceneInitialized="OnPreviewSceneInit"
                       SceneUpdated="OnPreviewSceneUpdated" />

        <!-- Back button -->
        <Button Grid.Column="0" x:Name="BackBtn" Click="OnBackClick"
                Background="#CC4a6a8a" Foreground="White"
                FontSize="12" FontWeight="Bold"
                Padding="10,6" CornerRadius="4"
                Margin="12" VerticalAlignment="Top" HorizontalAlignment="Left"
                ZIndex="10">
            ↩ Back
        </Button>

        <!-- Editor Sidebar -->
        <ScrollViewer Grid.Column="1" Background="#EE1a1a2e">
            <StackPanel Spacing="8" Margin="8">

                <!-- Monster List -->
                <TextBlock Text="CUSTOM MONSTERS" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <ComboBox x:Name="MonsterListCombo"
                              Width="170"
                              Background="#333" Foreground="White"
                              BorderBrush="#555" BorderThickness="1"
                              SelectionChanged="OnMonsterSelected" />
                    <Button x:Name="NewBtn" Click="OnNewMonster"
                            Background="#CC4a6a8a" Foreground="White" FontSize="11"
                            Padding="6,4" CornerRadius="4">
                        ＋ New
                    </Button>
                </StackPanel>
                <Button x:Name="DeleteBtn" Click="OnDeleteMonster"
                        Background="#CC6a3a3a" Foreground="White" FontSize="11"
                        Padding="8,4" CornerRadius="4">
                    🗑 Delete
                </Button>

                <Separator Background="#444" Height="1" />

                <!-- Name -->
                <TextBlock Text="NAME" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <TextBox x:Name="NameInput" Text="New Enemy"
                         KeyDown="OnPropertyKeyDown"
                         Background="#333" Foreground="White" FontSize="13"
                         BorderBrush="#555" BorderThickness="1"
                         Padding="6,4" />

                <Separator Background="#444" Height="1" />

                <!-- HP -->
                <TextBlock Text="MAX HP" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider x:Name="HPSlider" Minimum="10" Maximum="1000" Value="100"
                            Width="180" PropertyChanged="OnSliderChanged" />
                    <TextBox x:Name="HPInput" Text="100" Width="50"
                             KeyDown="OnPropertyKeyDown"
                             Background="#333" Foreground="White" FontSize="11"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="4,2" VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- Speed -->
                <TextBlock Text="SPEED" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider x:Name="SpeedSlider" Minimum="0.5" Maximum="10" Value="1.8"
                            Width="180"
                            TickFrequency="0.1"
                            PropertyChanged="OnSliderChanged" />
                    <TextBox x:Name="SpeedInput" Text="1.8" Width="50"
                             KeyDown="OnPropertyKeyDown"
                             Background="#333" Foreground="White" FontSize="11"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="4,2" VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- Gold Reward -->
                <TextBlock Text="GOLD REWARD" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider x:Name="GoldSlider" Minimum="1" Maximum="500" Value="10"
                            Width="180"
                            PropertyChanged="OnSliderChanged" />
                    <TextBox x:Name="GoldInput" Text="10" Width="50"
                             KeyDown="OnPropertyKeyDown"
                             Background="#333" Foreground="White" FontSize="11"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="4,2" VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- Radius -->
                <TextBlock Text="SIZE (RADIUS)" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider x:Name="RadiusSlider" Minimum="0.1" Maximum="1.0" Value="0.25"
                            Width="180"
                            TickFrequency="0.01"
                            PropertyChanged="OnSliderChanged" />
                    <TextBox x:Name="RadiusInput" Text="0.25" Width="50"
                             KeyDown="OnPropertyKeyDown"
                             Background="#333" Foreground="White" FontSize="11"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="4,2" VerticalContentAlignment="Center" />
                </StackPanel>

                <Separator Background="#444" Height="1" />

                <!-- Color -->
                <TextBlock Text="COLOR" Foreground="#AAA" FontSize="11" FontWeight="Bold" />

                <!-- Color preview square -->
                <Border x:Name="ColorPreview" Width="80" Height="40"
                        CornerRadius="6"
                        HorizontalAlignment="Left"
                        Background="#DC143C" />

                <!-- R -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="R" Foreground="#FF6666" FontSize="11" Width="16"
                               VerticalAlignment="Center" />
                    <Slider x:Name="ColorRSlider" Minimum="0" Maximum="255" Value="220"
                            Width="170"
                            PropertyChanged="OnColorSliderChanged" />
                    <TextBox x:Name="ColorRInput" Text="220" Width="40"
                             KeyDown="OnPropertyKeyDown"
                             Background="#333" Foreground="#FF6666" FontSize="11"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="4,2" VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- G -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="G" Foreground="#66FF66" FontSize="11" Width="16"
                               VerticalAlignment="Center" />
                    <Slider x:Name="ColorGSlider" Minimum="0" Maximum="255" Value="20"
                            Width="170"
                            PropertyChanged="OnColorSliderChanged" />
                    <TextBox x:Name="ColorGInput" Text="20" Width="40"
                             KeyDown="OnPropertyKeyDown"
                             Background="#333" Foreground="#66FF66" FontSize="11"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="4,2" VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- B -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="B" Foreground="#6699FF" FontSize="11" Width="16"
                               VerticalAlignment="Center" />
                    <Slider x:Name="ColorBSlider" Minimum="0" Maximum="255" Value="60"
                            Width="170"
                            PropertyChanged="OnColorSliderChanged" />
                    <TextBox x:Name="ColorBInput" Text="60" Width="40"
                             KeyDown="OnPropertyKeyDown"
                             Background="#333" Foreground="#6699FF" FontSize="11"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="4,2" VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- Preset colors -->
                <TextBlock Text="PRESETS" Foreground="#888" FontSize="10" />
                <WrapPanel>
                    <Button Click="OnPresetColorClick" Tag="#DC143C"
                            Width="28" Height="28" CornerRadius="4" Margin="2"
                            Background="#DC143C" BorderBrush="#555"
                            BorderThickness="1" Cursor="Hand" />
                    <Button Click="OnPresetColorClick" Tag="#FFD700"
                            Width="28" Height="28" CornerRadius="4" Margin="2"
                            Background="#FFD700" BorderBrush="#555"
                            BorderThickness="1" Cursor="Hand" />
                    <Button Click="OnPresetColorClick" Tag="#9400D3"
                            Width="28" Height="28" CornerRadius="4" Margin="2"
                            Background="#9400D3" BorderBrush="#555"
                            BorderThickness="1" Cursor="Hand" />
                    <Button Click="OnPresetColorClick" Tag="#00CED1"
                            Width="28" Height="28" CornerRadius="4" Margin="2"
                            Background="#00CED1" BorderBrush="#555"
                            BorderThickness="1" Cursor="Hand" />
                    <Button Click="OnPresetColorClick" Tag="#FF8C00"
                            Width="28" Height="28" CornerRadius="4" Margin="2"
                            Background="#FF8C00" BorderBrush="#555"
                            BorderThickness="1" Cursor="Hand" />
                    <Button Click="OnPresetColorClick" Tag="#32CD32"
                            Width="28" Height="28" CornerRadius="4" Margin="2"
                            Background="#32CD32" BorderBrush="#555"
                            BorderThickness="1" Cursor="Hand" />
                    <Button Click="OnPresetColorClick" Tag="#FF69B4"
                            Width="28" Height="28" CornerRadius="4" Margin="2"
                            Background="#FF69B4" BorderBrush="#555"
                            BorderThickness="1" Cursor="Hand" />
                    <Button Click="OnPresetColorClick" Tag="#4169E1"
                            Width="28" Height="28" CornerRadius="4" Margin="2"
                            Background="#4169E1" BorderBrush="#555"
                            BorderThickness="1" Cursor="Hand" />
                </WrapPanel>

                <Separator Background="#444" Height="1" />

                <!-- Stats summary -->
                <Border Background="#333" CornerRadius="6" Padding="10,8">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="SummaryName" Text="New Enemy"
                                   Foreground="White" FontSize="14" FontWeight="Bold" />
                        <TextBlock x:Name="SummaryHP" Text="HP: 100"
                                   Foreground="#CCC" FontSize="11" />
                        <TextBlock x:Name="SummarySpeed" Text="Speed: 1.8"
                                   Foreground="#CCC" FontSize="11" />
                        <TextBlock x:Name="SummaryGold" Text="Gold: 10"
                                   Foreground="#CCC" FontSize="11" />
                        <TextBlock x:Name="SummaryRadius" Text="Size: 0.25"
                                   Foreground="#CCC" FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- Save -->
                <Button x:Name="SaveBtn" Click="OnSaveMonster"
                        Background="#CC2d6a4a" Foreground="White" FontSize="13" FontWeight="Bold"
                        Padding="8,10" CornerRadius="6">
                    💾 Save Monster
                </Button>

                <TextBlock x:Name="StatusLabel" Text=""
                           Foreground="#AAA" FontSize="11"
                           TextWrapping="Wrap" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
