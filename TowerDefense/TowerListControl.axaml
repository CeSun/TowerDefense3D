<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:loc="clr-namespace:TowerDefense"
             x:Class="TowerDefense.TowerListControl">
    <Grid>
        <!-- 3D Preview fills entire screen -->
        <a:Aura3DView x:Name="PreviewView"
                       SceneInitialized="OnPreviewSceneInit"
                       SceneUpdated="OnPreviewSceneUpdated" />

        <!-- Selection overlay -->
        <Grid ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="#CC0d0d1a" Padding="12,8" Margin="8,8,8,0"
                    CornerRadius="6">
                <DockPanel>
                    <Button x:Name="BackBtn" Click="OnBackClick"
                            DockPanel.Dock="Left"
                            Background="#CC4a6a8a" Foreground="White"
                            FontSize="12" FontWeight="Bold"
                            Padding="10,6" CornerRadius="4"
                            Margin="0,0,12,0"
                            Content="{loc:Loc Game.Back}" />
                    <TextBlock DockPanel.Dock="Left" Text="{loc:Loc TowerList.Title}" Foreground="White"
                               FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock x:Name="ListStatus" DockPanel.Dock="Left" Foreground="#AAA" FontSize="13"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               Text="{loc:Loc TowerList.SelectHint}" />
                    <Button x:Name="NewBtn" Click="OnNewTower"
                            Background="#CC2d6a4a" Foreground="White"
                            FontSize="12" FontWeight="Bold"
                            Padding="12,6" CornerRadius="4"
                            HorizontalAlignment="Right"
                            Content="{loc:Loc TowerList.NewTower}" />
                </DockPanel>
            </Border>

            <!-- Tower card grid (left) -->
            <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="8,4,4,8">
                <WrapPanel x:Name="TowerCardGrid" Margin="4" />
            </ScrollViewer>

            <!-- Detail panel (right) -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="#EE1a1a2e" CornerRadius="6"
                    Padding="14" Margin="4,4,8,8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="DetailName" Text="{loc:Loc TowerList.SelectATower}"
                               Foreground="White" FontSize="22" FontWeight="Bold" />
                    <Separator Background="#444" Height="1" />
                    <TextBlock x:Name="DetailCost" Text="{loc:Loc TowerList.CostDash}"
                               Foreground="#FFD700" FontSize="13" />
                    <TextBlock x:Name="DetailDamage" Text="{loc:Loc TowerList.DamageDash}"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailRange" Text="{loc:Loc TowerList.RangeDash}"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailFireRate" Text="{loc:Loc TowerList.FireRateDash}"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailProjSpeed" Text="{loc:Loc TowerList.ProjSpeedDash}"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailShapes" Text="{loc:Loc TowerList.ShapesDash}"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailSpecial" Text=""
                               Foreground="#888" FontSize="11"
                               TextWrapping="Wrap" />

                    <Separator Background="#444" Height="1" />

                    <!-- Edit / Delete buttons -->
                    <StackPanel Spacing="4">
                        <Button x:Name="EditBtn" Click="OnEditTowerClick"
                                Background="#CC3a8a3a" Foreground="White"
                                FontSize="14" FontWeight="Bold"
                                Padding="14,10" CornerRadius="6"
                                HorizontalAlignment="Stretch"
                                IsVisible="False"
                                Content="{loc:Loc TowerList.EditTower}" />
                        <Button x:Name="DeleteBtn" Click="OnDeleteTower"
                                Background="#CC6a2a2a" Foreground="White"
                                FontSize="12"
                                Padding="10,6" CornerRadius="4"
                                HorizontalAlignment="Stretch"
                                IsVisible="False"
                                Content="{loc:Loc TowerList.DeleteTower}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
