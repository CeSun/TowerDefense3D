<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:loc="clr-namespace:TowerDefense"
             x:Class="TowerDefense.GameView">
    <Grid>
        <!-- 3D View fills entire area as background -->
        <a:Aura3DView x:Name="AuraView"
                       SceneInitialized="OnSceneInitialized"
                       SceneUpdated="OnSceneUpdated"
                       ObjectPicked="OnObjectPicked" />

        <!-- HP bar overlay (only used during gameplay) -->
        <Canvas x:Name="HpBarCanvas" IsHitTestVisible="False" />

        <!-- ============================================ -->
        <!-- LEVEL SELECT SCREEN                          -->
        <!-- ============================================ -->
        <Grid x:Name="LevelSelectPanel" ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="#CC0d0d1a" Padding="12,8" Margin="8,8,8,0"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Button x:Name="LevelSelectBackBtn" Click="OnMainMenuClick"
                            Background="#CC4a6a8a" Foreground="White"
                            FontSize="12" FontWeight="Bold"
                            Padding="10,6" CornerRadius="4"
                            Content="{loc:Loc Game.Back}" />
                    <TextBlock Text="{loc:Loc Game.SelectLevel}" Foreground="White"
                               FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock x:Name="LevelSelectStatus" Foreground="#AAA" FontSize="13"
                               VerticalAlignment="Center"
                               Text="{loc:Loc Game.ChooseLevel}" />
                </StackPanel>
            </Border>

            <!-- Level grid (left) -->
            <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="8,4,4,8">
                <WrapPanel x:Name="LevelGrid" Margin="4" />
            </ScrollViewer>

            <!-- Detail panel (right) -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="#EE1a1a2e" CornerRadius="6"
                    Padding="14" Margin="4,4,8,8">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="DetailLevelNum" Text="Level 1"
                               Foreground="White" FontSize="22" FontWeight="Bold" />
                    <Separator Background="#444" Height="1" />
                    <TextBlock x:Name="DetailWaves" Text="Waves: -"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailEnemies" Text="Enemies: -"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailPath" Text="Path: -"
                               Foreground="#AAA" FontSize="12" />
                    <TextBlock x:Name="DetailStatus" Text=""
                               Foreground="#888" FontSize="11"
                               TextWrapping="Wrap" />

                    <Button x:Name="LevelStartBtn" Click="OnLevelStartClick"
                            Background="#CC3a8a3a" Foreground="White"
                            FontSize="16" FontWeight="Bold"
                            Padding="20,12" CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            IsVisible="False"
                            Content="{loc:Loc Game.StartGame}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================ -->
        <!-- GAME HUD (shown during gameplay)             -->
        <!-- ============================================ -->
        <Grid x:Name="GameHudPanel" IsVisible="False" Margin="8" ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Top HUD -->
            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        Orientation="Horizontal" Spacing="12">
                <Button x:Name="GameBackBtn" Click="OnUnifiedBack"
                        Background="#CC4a6a8a" Foreground="White"
                        FontSize="12" FontWeight="Bold"
                        Padding="10,6" CornerRadius="4"
                        Content="{loc:Loc Game.Back}" />
                <Border Background="#CC1a1a2e" CornerRadius="6" Padding="10,5">
                    <TextBlock x:Name="GoldText" Text="Gold: 200"
                               Foreground="#FFD700" FontSize="16" FontWeight="Bold" />
                </Border>
                <Border Background="#CC1a1a2e" CornerRadius="6" Padding="10,5">
                    <TextBlock x:Name="LivesText" Text="Lives: 20"
                               Foreground="#FF6B6B" FontSize="16" FontWeight="Bold" />
                </Border>
                <Border Background="#CC1a1a2e" CornerRadius="6" Padding="10,5">
                    <TextBlock x:Name="WaveText" Text="Wave: -"
                               Foreground="#4ECDC4" FontSize="16" FontWeight="Bold" />
                </Border>
                <Border Background="#CC1a1a2e" CornerRadius="6" Padding="10,5">
                    <TextBlock x:Name="StatusText" Text="Select a tower and place it on green cells"
                               Foreground="White" FontSize="13" />
                </Border>
            </StackPanel>

            <!-- Right tower panel -->
            <StackPanel Grid.Row="1" Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0" Spacing="8">

                <StackPanel x:Name="TowerBtnPanel" IsVisible="False" Spacing="8">
                    <TextBlock Text="{loc:Loc Game.Towers}" Foreground="#AAA" FontSize="11" FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <!-- Tower buttons are generated dynamically from TowerDefinition.All -->
                </StackPanel>

                <Button x:Name="ResetBtn" Click="OnReset"
                        Background="#CC6a4a4a" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        Padding="14,8" CornerRadius="6" Width="180"
                        Content="{loc:Loc Game.Restart}" />
            </StackPanel>
        </Grid>

        <!-- ============================================ -->
        <!-- GAME OVER OVERLAY                            -->
        <!-- ============================================ -->
        <Panel x:Name="GameOverPanel" IsVisible="False"
               Background="#BB000000" ZIndex="100">
            <!-- Back button: top-left -->
            <Button x:Name="GameOverBackBtn" Click="OnBackToLevelSelect"
                    Background="#CC4a6a8a" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Padding="10,6" CornerRadius="4"
                    Margin="12" VerticalAlignment="Top" HorizontalAlignment="Left"
                    Content="{loc:Loc Game.Back}" />
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock x:Name="GameOverTitle" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="GameOverSubtext" FontSize="20"
                           HorizontalAlignment="Center" Foreground="#CCC" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12"
                            Margin="0,12,0,0">
                    <Button x:Name="GameOverReplayBtn" Click="OnReset"
                            Background="#CC2d5a27" Foreground="White"
                            FontSize="15" FontWeight="Bold"
                            Padding="20,10" CornerRadius="6"
                            Content="{loc:Loc Game.Retry}" />
                    <Button x:Name="GameOverMenuBtn" Click="OnBackToLevelSelect"
                            Background="#CC4a6a8a" Foreground="White"
                            FontSize="15" FontWeight="Bold"
                            Padding="20,10" CornerRadius="6"
                            Content="{loc:Loc Game.LevelSelect}" />
                    <Button x:Name="GameOverNextBtn" Click="OnNextLevelClick"
                            Background="#CC3a7a3a" Foreground="White"
                            FontSize="15" FontWeight="Bold"
                            Padding="20,10" CornerRadius="6"
                            IsVisible="False"
                            Content="{loc:Loc Game.NextLevel}" />
                </StackPanel>
            </StackPanel>
        </Panel>
    </Grid>
</UserControl>
