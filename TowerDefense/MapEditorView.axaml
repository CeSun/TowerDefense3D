<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             x:Class="TowerDefense.MapEditorView">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- 3D Map Preview -->
        <a:Aura3DView Grid.Column="0"
                       x:Name="EditorView"
                       SceneInitialized="OnEditorSceneInit"
                       SceneUpdated="OnEditorSceneUpdated"
                       ObjectPicked="OnEditorObjectPicked" />

        <!-- Editor Sidebar -->
        <ScrollViewer Grid.Column="1" Background="#EE1a1a2e">
            <StackPanel Spacing="8" Margin="8">
                <!-- Map File Operations -->
                <TextBlock Text="MAP FILE" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <ComboBox x:Name="MapListCombo"
                           SelectionChanged="OnMapSelected" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button x:Name="NewMapBtn" Click="OnNewMap"
                            Background="#CC4a6a8a" Foreground="White" FontSize="12"
                            Padding="8,4" CornerRadius="4">
                        🆕 New
                    </Button>
                    <Button x:Name="SaveBtn" Click="OnSaveMap"
                            Background="#CC2d6a4a" Foreground="White" FontSize="12"
                            Padding="8,4" CornerRadius="4">
                        💾 Save
                    </Button>
                    <Button x:Name="SaveAsBtn" Click="OnSaveAsMap"
                            Background="#CC4a6a4a" Foreground="White" FontSize="12"
                            Padding="8,4" CornerRadius="4">
                        📄 Save As
                    </Button>
                </StackPanel>

                <Separator Background="#444" Height="1" />

                <!-- Grid Settings -->
                <TextBlock Text="GRID" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Cols" Foreground="#AAA" FontSize="10" />
                        <TextBox x:Name="GridColsInput" Text="20"
                                 LostFocus="OnGridSizeChanged" Width="60"
                                 Background="#333" Foreground="White" FontSize="11"
                                 BorderBrush="#555" BorderThickness="1"
                                 Padding="4,2" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Rows" Foreground="#AAA" FontSize="10" />
                        <TextBox x:Name="GridRowsInput" Text="12"
                                 LostFocus="OnGridSizeChanged" Width="60"
                                 Background="#333" Foreground="White" FontSize="11"
                                 BorderBrush="#555" BorderThickness="1"
                                 Padding="4,2" />
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="GridStatusText" Foreground="#888" FontSize="10"
                           Text="Left click: add waypoint | Right click: delete" />

                <Separator Background="#444" Height="1" />

                <!-- Waypoints -->
                <TextBlock Text="WAYPOINTS" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <!-- Placement mode toggle -->
                <StackPanel Orientation="Horizontal" Spacing="3">
                    <Button x:Name="SetStartBtn" Click="OnSetStartMode"
                            Background="#CC2d6a2d" Foreground="White" FontSize="10"
                            Padding="6,3" CornerRadius="4">
                        🟢 Start
                    </Button>
                    <Button x:Name="AddWaypointBtn" Click="OnSetWaypointMode"
                            Background="#CC4a6a8a" Foreground="White" FontSize="10"
                            Padding="6,3" CornerRadius="4">
                        📍 Waypoint
                    </Button>
                    <Button x:Name="SetEndBtn" Click="OnSetEndMode"
                            Background="#CC4a4a2a" Foreground="White" FontSize="10"
                            Padding="6,3" CornerRadius="4">
                        🔴 End
                    </Button>
                </StackPanel>
                <TextBlock Text="🖱 Left click: place | Right click: remove"
                           Foreground="#AAA" FontSize="10" Margin="0,2,0,0" />

                <Separator Background="#444" Height="1" />

                <!-- Waves -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="WAVES" Foreground="#AAA" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="WaveCountText" Foreground="#888" FontSize="10"
                               VerticalAlignment="Center" Text="(5)" />
                </StackPanel>
                <ListBox x:Name="WaveList" Height="140"
                         SelectionMode="Single"
                         SelectionChanged="OnWaveListSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="11" Foreground="White" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button x:Name="AddWaveBtn" Click="OnAddWave"
                            Background="#CC2d6a4a" Foreground="White" FontSize="11"
                            Padding="8,4" CornerRadius="4">
                        ＋ Add Wave
                    </Button>
                    <Button x:Name="DeleteWaveBtn" Click="OnDeleteWave"
                            Background="#CC6a2a2a" Foreground="White" FontSize="11"
                            Padding="8,4" CornerRadius="4">
                        ✕ Delete Wave
                    </Button>
                </StackPanel>

                <!-- Edit Selected Wave -->
                <TextBlock Text="EDIT WAVE" Foreground="#AAA" FontSize="11" FontWeight="Bold" />
                <Border x:Name="WaveEditPanel" Background="#22FFFFFF" CornerRadius="4" Padding="6">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Delay:" Foreground="#AAA" FontSize="11"
                                       VerticalAlignment="Center" />
                            <NumericUpDown x:Name="WaveDelayInput" Minimum="0" Maximum="60"
                                           Value="5" Increment="0.5" Width="70" FormatString="F1"
                                           ValueChanged="OnWaveDelayChanged" />
                            <TextBlock Text="s" Foreground="#888" FontSize="10"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Entries:" Foreground="#AAA" FontSize="10" />
                        <ListBox x:Name="EntryList" Height="80"
                                 SelectionChanged="OnEntryListSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="10" Foreground="White" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <!-- Edit selected entry -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <StackPanel Spacing="1">
                                <TextBlock Text="Count" Foreground="#888" FontSize="9" />
                                <NumericUpDown x:Name="EntryCountInput" Minimum="1" Maximum="50"
                                               Value="3" Increment="1" Width="55"
                                               ValueChanged="OnEntryCountChanged" />
                            </StackPanel>
                            <StackPanel Spacing="1">
                                <TextBlock Text="Interval" Foreground="#888" FontSize="9" />
                                <NumericUpDown x:Name="EntryIntervalInput" Minimum="0.2" Maximum="10"
                                               Value="1.0" Increment="0.1" Width="55" FormatString="F1"
                                               ValueChanged="OnEntryIntervalChanged" />
                                <TextBlock Text="s" Foreground="#666" FontSize="8" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <ComboBox x:Name="EnemyTypeCombo" Width="80" FontSize="10"
                                      SelectionChanged="OnEntryEnemyTypeChanged" />
                            <Button x:Name="AddEntryBtn" Click="OnAddEntry"
                                    Background="#CC2d5a6a" Foreground="White" FontSize="10"
                                    Padding="6,2" CornerRadius="4">
                                ＋ Entry
                            </Button>
                            <Button x:Name="DeleteEntryBtn" Click="OnDeleteEntry"
                                    Background="#CC6a2a2a" Foreground="White" FontSize="10"
                                    Padding="6,2" CornerRadius="4">
                                ✕
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Separator Background="#444" Height="1" />

                <!-- Test Map -->
                <Button x:Name="TestMapBtn" Click="OnTestMap"
                        Background="#CC3a8a3a" Foreground="White"
                        FontSize="14" FontWeight="Bold"
                        Padding="14,8" CornerRadius="6">
                    ▶ Test Map
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
