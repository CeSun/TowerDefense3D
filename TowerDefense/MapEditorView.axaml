<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:loc="clr-namespace:TowerDefense"
             x:Class="TowerDefense.MapEditorView">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- ============================================ -->
        <!-- LEFT: Waypoint Panel                         -->
        <!-- ============================================ -->
        <Border Grid.Column="0" Background="#EE0d0d1a">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <!-- Back button -->
                <Button Grid.Row="0" x:Name="BackBtn" Click="OnBackClick"
                        Background="#CC4a6a8a" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        Padding="10,6" CornerRadius="4"
                        Margin="8" HorizontalAlignment="Left"
                        Content="{loc:Loc Game.Back}" />

                <!-- Waypoint Type Selection -->
                <StackPanel Grid.Row="1" Margin="8,0,8,4" Spacing="4">
                    <TextBlock Text="{loc:Loc MapEditor.WaypointType}" Foreground="#AAA" FontSize="12" FontWeight="Bold" />
                    <Button x:Name="SetStartBtn" Click="OnSetStartMode"
                            Background="#CC2d6a2d" Foreground="White"
                            FontSize="13" FontWeight="Bold"
                            Padding="10,8" CornerRadius="6"
                            Content="{loc:Loc MapEditor.Start}" />
                    <Button x:Name="AddWaypointBtn" Click="OnSetWaypointMode"
                            Background="#CC4a6a8a" Foreground="White"
                            FontSize="13" FontWeight="Bold"
                            Padding="10,8" CornerRadius="6"
                            Content="{loc:Loc MapEditor.Waypoint}" />
                    <Button x:Name="SetEndBtn" Click="OnSetEndMode"
                            Background="#CC6a2a2a" Foreground="White"
                            FontSize="13" FontWeight="Bold"
                            Padding="10,8" CornerRadius="6"
                            Content="{loc:Loc MapEditor.End}" />
                    <TextBlock Text="{loc:Loc MapEditor.TapHint}"
                               Foreground="#888" FontSize="10" Margin="0,2,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- Spacer row to push info panel to bottom -->

                <!-- Selected Waypoint Info Panel -->
                <Border Grid.Row="3" x:Name="WaypointInfoPanel" Background="#22FFFFFF"
                        CornerRadius="6" Padding="10" Margin="8,0,8,8"
                        IsVisible="False">
                    <StackPanel Spacing="8">
                        <!-- Type badge -->
                        <Border x:Name="WaypointTypeBadge" CornerRadius="4" Padding="8,4"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="WaypointTypeText" Foreground="White"
                                       FontSize="13" FontWeight="Bold" />
                        </Border>
                        <!-- Coordinates -->
                        <Border Background="#333" CornerRadius="4" Padding="10,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Loc MapEditor.Coord}" Foreground="#888" FontSize="11" />
                                <TextBlock x:Name="WaypointCoordText" Foreground="#FFF" FontSize="18" FontWeight="Bold"
                                           Text="(0, 0)" />
                            </StackPanel>
                        </Border>
                        <!-- Delete button -->
                        <Button x:Name="DeleteWaypointBtn" Click="OnDeleteSelectedWaypoint"
                                Background="#CC8a2a2a" Foreground="White"
                                FontSize="15" FontWeight="Bold"
                                Padding="10,12" CornerRadius="6"
                                Content="{loc:Loc MapEditor.DeleteWaypoint}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CENTER: 3D Map Preview                       -->
        <!-- ============================================ -->
        <a:Aura3DView Grid.Column="1"
                       x:Name="EditorView"
                       SceneInitialized="OnEditorSceneInit"
                       SceneUpdated="OnEditorSceneUpdated"
                       ObjectPicked="OnEditorObjectPicked" />

        <!-- ============================================ -->
        <!-- RIGHT: Settings Panel                        -->
        <!-- ============================================ -->
        <ScrollViewer Grid.Column="2" Background="#EE1a1a2e">
            <StackPanel Spacing="8" Margin="8">
                <!-- Save -->
                <Button x:Name="SaveBtn" Click="OnSaveMap"
                        Background="#CC2d6a4a" Foreground="White" FontSize="12" FontWeight="Bold"
                        Padding="10,8" CornerRadius="6"
                        Content="{loc:Loc MapEditor.Save}" />

                <Separator Background="#444" Height="1" />

                <!-- Grid Settings -->
                <TextBlock Text="{loc:Loc MapEditor.Grid}" Foreground="#AAA" FontSize="12" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{loc:Loc MapEditor.Cols}" Foreground="#AAA" FontSize="10" />
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <TextBox x:Name="GridColsInput" Text="20"
                                     KeyDown="OnGridKeyDown" Width="48"
                                     Background="#333" Foreground="White" FontSize="12"
                                     BorderBrush="#555" BorderThickness="1"
                                     Padding="4,2" VerticalContentAlignment="Center" />
                            <StackPanel Spacing="1">
                                <Button x:Name="GridColsUpBtn" Click="OnGridColsUp"
                                        Background="#CC4a6a8a" Foreground="White" FontSize="9"
                                        Padding="6,2" CornerRadius="2">▲</Button>
                                <Button x:Name="GridColsDownBtn" Click="OnGridColsDown"
                                        Background="#CC4a6a8a" Foreground="White" FontSize="9"
                                        Padding="6,2" CornerRadius="2">▼</Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="{loc:Loc MapEditor.Rows}" Foreground="#AAA" FontSize="10" />
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <TextBox x:Name="GridRowsInput" Text="12"
                                     KeyDown="OnGridKeyDown" Width="48"
                                     Background="#333" Foreground="White" FontSize="12"
                                     BorderBrush="#555" BorderThickness="1"
                                     Padding="4,2" VerticalContentAlignment="Center" />
                            <StackPanel Spacing="1">
                                <Button x:Name="GridRowsUpBtn" Click="OnGridRowsUp"
                                        Background="#CC4a6a8a" Foreground="White" FontSize="9"
                                        Padding="6,2" CornerRadius="2">▲</Button>
                                <Button x:Name="GridRowsDownBtn" Click="OnGridRowsDown"
                                        Background="#CC4a6a8a" Foreground="White" FontSize="9"
                                        Padding="6,2" CornerRadius="2">▼</Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="GridStatusText" Foreground="#888" FontSize="10"
                           Text="{loc:Loc MapEditor.GridHint}" />

                <Separator Background="#444" Height="1" />

                <!-- Waves -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{loc:Loc MapEditor.WavesTitle}" Foreground="#AAA" FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="WaveCountText" Foreground="#888" FontSize="10"
                               VerticalAlignment="Center" Text="(0)" />
                </StackPanel>
                <ListBox x:Name="WaveList" Height="100" SelectionMode="Single"
                         SelectionChanged="OnWaveListSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="11" Foreground="White" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button x:Name="AddWaveBtn" Click="OnAddWave"
                            Background="#CC2d6a4a" Foreground="White" FontSize="11"
                            Padding="8,6" CornerRadius="4"
                            Content="{loc:Loc MapEditor.AddWave}" />
                    <Button x:Name="DeleteWaveBtn" Click="OnDeleteWave"
                            Background="#CC6a2a2a" Foreground="White" FontSize="11"
                            Padding="8,6" CornerRadius="4"
                            Content="{loc:Loc MapEditor.DeleteWave}" />
                </StackPanel>

                <!-- Edit Selected Wave -->
                <TextBlock Text="{loc:Loc MapEditor.EditWave}" Foreground="#AAA" FontSize="12" FontWeight="Bold" />
                <Border x:Name="WaveEditPanel" Background="#22FFFFFF" CornerRadius="4" Padding="6">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{loc:Loc MapEditor.Delay}" Foreground="#AAA" FontSize="10"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="WaveDelayInput" Text="5.0"
                                     KeyDown="OnWaveDelayKeyDown" Width="44"
                                     Background="#333" Foreground="White" FontSize="11"
                                     BorderBrush="#555" BorderThickness="1"
                                     Padding="4,2" VerticalContentAlignment="Center" />
                            <StackPanel Spacing="1">
                                <Button x:Name="WaveDelayUpBtn" Click="OnWaveDelayUp"
                                        Background="#CC4a6a8a" Foreground="White" FontSize="8"
                                        Padding="6,2" CornerRadius="2">▲</Button>
                                <Button x:Name="WaveDelayDownBtn" Click="OnWaveDelayDown"
                                        Background="#CC4a6a8a" Foreground="White" FontSize="8"
                                        Padding="6,2" CornerRadius="2">▼</Button>
                            </StackPanel>
                            <TextBlock Text="{loc:Loc MapEditor.SecondAbbr}" Foreground="#888" FontSize="10"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{loc:Loc MapEditor.Entries}" Foreground="#AAA" FontSize="10" />
                        <ListBox x:Name="EntryList" Height="70"
                                 SelectionChanged="OnEntryListSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="10" Foreground="White" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Spacing="3">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{loc:Loc MapEditor.Type}" Foreground="#888" FontSize="9"
                                           VerticalAlignment="Center" Width="36" />
                                <ComboBox x:Name="EnemyTypeCombo" Width="80" FontSize="10"
                                          SelectionChanged="OnEntryEnemyTypeChanged" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{loc:Loc MapEditor.Count}" Foreground="#888" FontSize="9"
                                           VerticalAlignment="Center" Width="36" />
                                <TextBox x:Name="EntryCountInput" Text="3"
                                         KeyDown="OnEntryCountKeyDown" Width="44"
                                         Background="#333" Foreground="White" FontSize="10"
                                         BorderBrush="#555" BorderThickness="1"
                                         Padding="4,2" VerticalContentAlignment="Center" />
                                <StackPanel Spacing="1">
                                    <Button x:Name="EntryCountUpBtn" Click="OnEntryCountUp"
                                            Background="#CC4a6a8a" Foreground="White" FontSize="7"
                                            Padding="6,2" CornerRadius="2">▲</Button>
                                    <Button x:Name="EntryCountDownBtn" Click="OnEntryCountDown"
                                            Background="#CC4a6a8a" Foreground="White" FontSize="7"
                                            Padding="6,2" CornerRadius="2">▼</Button>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{loc:Loc MapEditor.Interval}" Foreground="#888" FontSize="9"
                                           VerticalAlignment="Center" Width="36" />
                                <TextBox x:Name="EntryIntervalInput" Text="1.0"
                                         KeyDown="OnEntryIntervalKeyDown" Width="44"
                                         Background="#333" Foreground="White" FontSize="10"
                                         BorderBrush="#555" BorderThickness="1"
                                         Padding="4,2" VerticalContentAlignment="Center" />
                                <StackPanel Spacing="1">
                                    <Button x:Name="EntryIntervalUpBtn" Click="OnEntryIntervalUp"
                                            Background="#CC4a6a8a" Foreground="White" FontSize="7"
                                            Padding="6,2" CornerRadius="2">▲</Button>
                                    <Button x:Name="EntryIntervalDownBtn" Click="OnEntryIntervalDown"
                                            Background="#CC4a6a8a" Foreground="White" FontSize="7"
                                            Padding="6,2" CornerRadius="2">▼</Button>
                                </StackPanel>
                                <TextBlock Text="{loc:Loc MapEditor.SecondAbbr}" Foreground="#888" FontSize="9"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="AddEntryBtn" Click="OnAddEntry"
                                        Background="#CC2d5a6a" Foreground="White" FontSize="10"
                                        Padding="8,4" CornerRadius="4"
                                        Content="{loc:Loc MapEditor.AddEntry}" />
                                <Button x:Name="DeleteEntryBtn" Click="OnDeleteEntry"
                                        Background="#CC6a2a2a" Foreground="White" FontSize="10"
                                        Padding="8,4" CornerRadius="4"
                                        Content="{loc:Loc MapEditor.DeleteEntry}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Separator Background="#444" Height="1" />

                <!-- Test Map -->
                <Button x:Name="TestMapBtn" Click="OnTestMap"
                        Background="#CC3a8a3a" Foreground="White"
                        FontSize="15" FontWeight="Bold"
                        Padding="14,10" CornerRadius="6"
                        Content="{loc:Loc MapEditor.TestMap}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
