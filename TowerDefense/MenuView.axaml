<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:TowerDefense"
             x:Class="TowerDefense.MenuView">
    <Grid Background="#FF1a1a2e">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
            <!-- Title -->
            <TextBlock Text="{loc:Loc Menu.Title}"
                       FontSize="48" FontWeight="Bold"
                       Foreground="#FFD700"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Loc Menu.Subtitle}"
                       FontSize="16"
                       Foreground="#888"
                       HorizontalAlignment="Center"
                       Margin="0,-12,0,0" />

            <Separator Background="#333" Height="1" Width="400" Margin="0,8" />

            <!-- Play Game Button -->
            <Button x:Name="PlayGameBtn" Click="OnPlayGameClick"
                    Background="#CC2d5a27" Foreground="White"
                    FontSize="22" FontWeight="Bold"
                    Padding="40,18" CornerRadius="12" Width="320"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Cursor="Hand"
                    Content="{loc:Loc Menu.PlayGame}" />

            <!-- Map Editor Button -->
            <Button x:Name="EditorBtn" Click="OnOpenEditorClick"
                    Background="#CC4a6a8a" Foreground="White"
                    FontSize="22" FontWeight="Bold"
                    Padding="40,18" CornerRadius="12" Width="320"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Cursor="Hand"
                    Content="{loc:Loc Menu.MapEditor}" />

            <!-- Monster Editor Button -->
            <Button x:Name="MonsterEditorBtn" Click="OnOpenMonsterEditorClick"
                    Background="#CC8a5a4a" Foreground="White"
                    FontSize="22" FontWeight="Bold"
                    Padding="40,18" CornerRadius="12" Width="320"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Cursor="Hand"
                    Content="{loc:Loc Menu.MonsterEditor}" />

            <!-- Tower Editor Button -->
            <Button x:Name="TowerEditorBtn" Click="OnOpenTowerEditorClick"
                    Background="#CC5a5a8a" Foreground="White"
                    FontSize="22" FontWeight="Bold"
                    Padding="40,18" CornerRadius="12" Width="320"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Cursor="Hand"
                    Content="{loc:Loc Menu.TowerEditor}" />

            <!-- Map count hint -->
            <TextBlock x:Name="MapCountLabel" Text=""
                       Foreground="#666" FontSize="12"
                       HorizontalAlignment="Center" />

            <Separator Background="#333" Height="1" Width="320" />

            <!-- Reset Data -->
            <Button x:Name="ResetDataBtn" Click="OnResetDataClick"
                    Background="#CC4a4a6a" Foreground="#CCC"
                    FontSize="14" FontWeight="Bold"
                    Padding="16,10" CornerRadius="8" Width="320"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Cursor="Hand"
                    Content="{loc:Loc Menu.Reset}" />

            <!-- Language Switcher -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12"
                        Margin="0,8,0,0">
                <Button x:Name="LangEnBtn" Click="OnSwitchToEnglish"
                        Background="#CC3a5a8a" Foreground="White"
                        FontSize="12" FontWeight="Bold"
                        Padding="12,6" CornerRadius="6"
                        Cursor="Hand"
                        Content="{loc:Loc Menu.LanguageEn}" />
                <Button x:Name="LangZhBtn" Click="OnSwitchToChinese"
                        Background="#CC5a3a3a" Foreground="White"
                        FontSize="12" FontWeight="Bold"
                        Padding="12,6" CornerRadius="6"
                        Cursor="Hand"
                        Content="{loc:Loc Menu.LanguageZh}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
